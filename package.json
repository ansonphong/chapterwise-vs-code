{
  "name": "chapterwise",
  "displayName": "ChapterWise",
  "description": "Codex file format Manuscript editing with tree navigation, distraction-free prose editing, and format validation.",
  "version": "0.3.2",
  "publisher": "StudioPhong",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ansonphong/chapterwise-vs-code"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Formatters"
  ],
  "keywords": [
    "codex",
    "yaml",
    "writing",
    "storytelling",
    "worldbuilding"
  ],
  "activationEvents": [
    "workspaceContains:**/*.codex.yaml",
    "workspaceContains:**/*.codex.json",
    "workspaceContains:**/*.codex"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "chapterwise.openNavigator",
        "title": "ChapterWise: Open Navigator"
      },
      {
        "command": "chapterwise.filterByType",
        "title": "ChapterWise: Filter Nodes by Type",
        "icon": "$(filter)"
      },
      {
        "command": "chapterwise.openWriterView",
        "title": "ChapterWise: Open Writer View",
        "icon": "$(edit)"
      },
      {
        "command": "chapterwise.refresh",
        "title": "ChapterWise: Refresh Tree",
        "icon": "$(refresh)"
      },
      {
        "command": "chapterwise.goToYaml",
        "title": "Go to YAML/JSON"
      },
      {
        "command": "chapterwise.copyId",
        "title": "Copy ID"
      },
      {
        "command": "chapterwise.toggleFields",
        "title": "ChapterWise: Toggle Field Display",
        "icon": "$(list-tree)"
      },
      {
        "command": "chapterwise.autoFix",
        "title": "ChapterWise: Auto-Fix Document",
        "icon": "$(wand)"
      },
      {
        "command": "chapterwise.autoFixRegenIds",
        "title": "ChapterWise: Auto-Fix (Regenerate All IDs)",
        "icon": "$(sync)"
      },
      {
        "command": "chapterwise.explodeCodex",
        "title": "ChapterWise: Explode Codex (Extract Children to Files)"
      },
      {
        "command": "chapterwise.implodeCodex",
        "title": "ChapterWise: Implode Codex (Merge Included Files)"
      },
      {
        "command": "chapterwise.updateWordCount",
        "title": "ChapterWise: Update Word Count"
      },
      {
        "command": "chapterwise.generateTags",
        "title": "ChapterWise: Generate Tags"
      },
      {
        "command": "chapterwise.generateIndex",
        "title": "ChapterWise: Generate Index",
        "icon": "$(file-add)"
      },
      {
        "command": "chapterwise.regenerateIndex",
        "title": "ChapterWise: Regenerate Index",
        "icon": "$(sync)"
      },
      {
        "command": "chapterwise.createIndexFile",
        "title": "ChapterWise: Create Index File",
        "icon": "$(new-file)"
      },
      {
        "command": "chapterwise.convertToMarkdown",
        "title": "ChapterWise: Convert to Markdown (Codex Lite)"
      },
      {
        "command": "chapterwise.convertToCodex",
        "title": "ChapterWise: Convert Markdown to Codex"
      },
      {
        "command": "chapterwise.git.setupWizard",
        "title": "ChapterWise: Git Setup Wizard (Recommended for Beginners)",
        "icon": "$(rocket)"
      },
      {
        "command": "chapterwise.git.initRepository",
        "title": "ChapterWise: Initialize Git Repository",
        "icon": "$(repo-create)"
      },
      {
        "command": "chapterwise.git.ensureGitIgnore",
        "title": "ChapterWise: Create/Update .gitignore for Writing Projects",
        "icon": "$(file-add)"
      },
      {
        "command": "chapterwise.git.setupLFS",
        "title": "ChapterWise: Setup Git LFS for Large Files",
        "icon": "$(database)"
      },
      {
        "command": "chapterwise.addChildNode",
        "title": "Add Child Node",
        "icon": "$(add)"
      },
      {
        "command": "chapterwise.addSiblingNode",
        "title": "Add Sibling Node"
      },
      {
        "command": "chapterwise.removeNode",
        "title": "Remove from Tree",
        "icon": "$(trash)"
      },
      {
        "command": "chapterwise.deleteNodePermanently",
        "title": "Delete Node Permanently"
      },
      {
        "command": "chapterwise.renameNode",
        "title": "Rename Node",
        "icon": "$(edit)"
      },
      {
        "command": "chapterwise.moveNodeUp",
        "title": "Move Node Up"
      },
      {
        "command": "chapterwise.moveNodeDown",
        "title": "Move Node Down"
      },
      {
        "command": "chapterwise.changeColor",
        "title": "Change Color",
        "icon": "$(symbol-color)"
      },
      {
        "command": "chapterwise.switchToIndexMode",
        "title": "Show Index View",
        "icon": "$(list-tree)"
      },
      {
        "command": "chapterwise.setContextFolder",
        "title": "Set as ChapterWise Context Folder",
        "icon": "$(folder-active)"
      },
      {
        "command": "chapterwise.setContextFile",
        "title": "Set as ChapterWise Context File",
        "icon": "$(file-code)"
      },
      {
        "command": "chapterwise.resetContext",
        "title": "Reset to Workspace Root",
        "icon": "$(home)"
      },
      {
        "command": "chapterwise.navigateToEntityInCodeView",
        "title": "Open in Code View",
        "icon": "$(code)"
      },
      {
        "command": "chapterwise.navigateToFieldInCodeView",
        "title": "Open Field in Code View",
        "icon": "$(code)"
      },
      {
        "command": "chapterwise.addField",
        "title": "Add Field"
      },
      {
        "command": "chapterwise.deleteField",
        "title": "Delete Field"
      },
      {
        "command": "chapterwise.renameField",
        "title": "Rename Field"
      },
      {
        "command": "chapterwise.changeType",
        "title": "Change Type"
      },
      {
        "command": "chapterwise.changeIcon",
        "title": "Change Icon/Emoji"
      },
      {
        "command": "chapterwise.addTags",
        "title": "Add Tags"
      },
      {
        "command": "chapterwise.addRelation",
        "title": "Add Relation"
      },
      {
        "command": "chapterwise.duplicateNode",
        "title": "Duplicate",
        "icon": "$(copy)"
      },
      {
        "command": "chapterwise.cutNode",
        "title": "Cut",
        "icon": "$(cut)"
      },
      {
        "command": "chapterwise.pasteNodeAsChild",
        "title": "Paste as Child"
      },
      {
        "command": "chapterwise.pasteNodeAsSibling",
        "title": "Paste as Sibling"
      },
      {
        "command": "chapterwise.extractToFile",
        "title": "Extract to File"
      },
      {
        "command": "chapterwise.moveToTrash",
        "title": "Move to Trash",
        "icon": "$(trash)"
      },
      {
        "command": "chapterwise.restoreFromTrash",
        "title": "Restore from Trash"
      },
      {
        "command": "chapterwise.emptyTrash",
        "title": "Empty Trash"
      },
      {
        "command": "chapterwise.openInFinder",
        "title": "Reveal in File Explorer"
      },
      {
        "command": "chapterwise.copyPath",
        "title": "Copy Path"
      },
      {
        "command": "chapterwise.addChildFile",
        "title": "Add File"
      },
      {
        "command": "chapterwise.addChildFolder",
        "title": "New Subfolder"
      },
      {
        "command": "chapterwise.inlineThisFile",
        "title": "Inline This File"
      },
      {
        "command": "chapterwise.renameFolder",
        "title": "Rename Folder"
      },
      {
        "command": "chapterwise.batchMoveToTrash",
        "title": "Move Selected to Trash",
        "icon": "$(trash)"
      },
      {
        "command": "chapterwise.batchAddTags",
        "title": "Add Tags to Selected"
      },
      {
        "command": "chapterwise.importScrivener",
        "title": "ChapterWise: Import Scrivener Project",
        "icon": "$(file-add)"
      },
      {
        "command": "chapterwise.search",
        "title": "ChapterWise: Search",
        "icon": "$(search)"
      },
      {
        "command": "chapterwise.rebuildSearchIndex",
        "title": "ChapterWise: Rebuild Search Index",
        "icon": "$(sync)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chapterwise",
          "title": "ChapterWise",
          "icon": "media/codex-v4.svg"
        }
      ]
    },
    "views": {
      "chapterwise": [
        {
          "id": "chapterwiseMaster",
          "name": "Master Index",
          "when": "chapterwise.hasMultipleIndexes"
        },
        {
          "id": "chapterwiseIndex0",
          "name": "Index 1",
          "when": "chapterwise.index0Visible"
        },
        {
          "id": "chapterwiseIndex1",
          "name": "Index 2",
          "when": "chapterwise.index1Visible"
        },
        {
          "id": "chapterwiseIndex2",
          "name": "Index 3",
          "when": "chapterwise.index2Visible"
        },
        {
          "id": "chapterwiseIndex3",
          "name": "Index 4",
          "when": "chapterwise.index3Visible"
        },
        {
          "id": "chapterwiseIndex4",
          "name": "Index 5",
          "when": "chapterwise.index4Visible"
        },
        {
          "id": "chapterwiseIndex5",
          "name": "Index 6",
          "when": "chapterwise.index5Visible"
        },
        {
          "id": "chapterwiseIndex6",
          "name": "Index 7",
          "when": "chapterwise.index6Visible"
        },
        {
          "id": "chapterwiseIndex7",
          "name": "Index 8",
          "when": "chapterwise.index7Visible"
        },
        {
          "id": "chapterwiseNavigator",
          "name": "ChapterWise Navigator",
          "when": "!chapterwise.hasMultipleIndexes"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "chapterwiseMaster",
        "contents": "No orphan files found.\n\nAll files are organized within sub-indexes."
      },
      {
        "view": "chapterwiseNavigator",
        "contents": "No Codex file is currently open.\n\nOpen a .codex.yaml or .codex.json file to see its structure here.\n\n[Open Codex File](command:workbench.action.files.openFile)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "chapterwise.setContextFolder",
          "when": "explorerResourceIsFolder",
          "group": "2_workspace@1"
        },
        {
          "command": "chapterwise.setContextFile",
          "when": "resourceExtname == .yaml && resourceFilename =~ /\\.codex\\.yaml$/",
          "group": "2_workspace@2"
        }
      ],
      "editor/title": [
        {
          "command": "chapterwise.autoFix",
          "when": "resourceFilename =~ /\\.codex\\.(yaml|json)$/ || resourceFilename =~ /\\.codex$/",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "chapterwise.autoFix",
          "when": "resourceFilename =~ /\\.codex\\.(yaml|json)$/ || resourceFilename =~ /\\.codex$/",
          "group": "codex@1"
        },
        {
          "command": "chapterwise.autoFixRegenIds",
          "when": "resourceFilename =~ /\\.codex\\.(yaml|json)$/ || resourceFilename =~ /\\.codex$/",
          "group": "codex@2"
        }
      ],
      "editor/context": [
        {
          "command": "chapterwise.autoFix",
          "when": "resourceFilename =~ /\\.codex\\.(yaml|json)$/ || resourceFilename =~ /\\.codex$/",
          "group": "codex"
        }
      ],
      "view/title": [
        {
          "command": "chapterwise.search",
          "when": "view == chapterwiseNavigator",
          "group": "navigation@1"
        },
        {
          "command": "chapterwise.autoFix",
          "when": "view == chapterwiseNavigator",
          "group": "navigation@2"
        },
        {
          "command": "chapterwise.filterByType",
          "when": "view == chapterwiseNavigator",
          "group": "navigation@3"
        },
        {
          "command": "chapterwise.refresh",
          "when": "view == chapterwiseNavigator",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "chapterwise.openWriterView",
          "when": "viewItem == codexNode",
          "group": "inline"
        },
        {
          "command": "chapterwise.addChildNode",
          "when": "viewItem == codexNode",
          "group": "1_add@1"
        },
        {
          "command": "chapterwise.addSiblingNode",
          "when": "viewItem == codexNode",
          "group": "1_add@2"
        },
        {
          "command": "chapterwise.addField",
          "when": "viewItem == codexNode",
          "group": "1_add@3"
        },
        {
          "command": "chapterwise.renameNode",
          "when": "viewItem == codexNode",
          "group": "2_edit@1"
        },
        {
          "command": "chapterwise.changeColor",
          "when": "viewItem == codexNode",
          "group": "2_edit@2"
        },
        {
          "command": "chapterwise.changeType",
          "when": "viewItem == codexNode",
          "group": "2_edit@3"
        },
        {
          "command": "chapterwise.changeIcon",
          "when": "viewItem == codexNode",
          "group": "2_edit@4"
        },
        {
          "command": "chapterwise.addTags",
          "when": "viewItem == codexNode",
          "group": "2_edit@5"
        },
        {
          "command": "chapterwise.addRelation",
          "when": "viewItem == codexNode",
          "group": "2_edit@6"
        },
        {
          "command": "chapterwise.cutNode",
          "when": "viewItem == codexNode",
          "group": "3_move@3"
        },
        {
          "command": "chapterwise.pasteNodeAsChild",
          "when": "viewItem == codexNode",
          "group": "3_move@4"
        },
        {
          "command": "chapterwise.pasteNodeAsSibling",
          "when": "viewItem == codexNode",
          "group": "3_move@5"
        },
        {
          "command": "chapterwise.goToYaml",
          "when": "viewItem == codexNode",
          "group": "4_navigate@1"
        },
        {
          "command": "chapterwise.copyId",
          "when": "viewItem == codexNode",
          "group": "4_navigate@2"
        },
        {
          "command": "chapterwise.duplicateNode",
          "when": "viewItem == codexNode",
          "group": "4_navigate@3"
        },
        {
          "command": "chapterwise.extractToFile",
          "when": "viewItem == codexNode",
          "group": "4_navigate@4"
        },
        {
          "command": "chapterwise.moveToTrash",
          "when": "viewItem == codexNode",
          "group": "5_delete@1"
        },
        {
          "command": "chapterwise.deleteNodePermanently",
          "when": "viewItem == codexNode",
          "group": "5_delete@2"
        },
        {
          "command": "chapterwise.addChildNode",
          "when": "viewItem == indexNode",
          "group": "1_add@1"
        },
        {
          "command": "chapterwise.addSiblingNode",
          "when": "viewItem == indexNode",
          "group": "1_add@2"
        },
        {
          "command": "chapterwise.addField",
          "when": "viewItem == indexNode",
          "group": "1_add@3"
        },
        {
          "command": "chapterwise.renameNode",
          "when": "viewItem == indexNode",
          "group": "2_edit@1"
        },
        {
          "command": "chapterwise.changeType",
          "when": "viewItem == indexNode",
          "group": "2_edit@2"
        },
        {
          "command": "chapterwise.changeIcon",
          "when": "viewItem == indexNode",
          "group": "2_edit@3"
        },
        {
          "command": "chapterwise.addTags",
          "when": "viewItem == indexNode",
          "group": "2_edit@4"
        },
        {
          "command": "chapterwise.addRelation",
          "when": "viewItem == indexNode",
          "group": "2_edit@5"
        },
        {
          "command": "chapterwise.moveNodeUp",
          "when": "viewItem == indexNode",
          "group": "3_move@1"
        },
        {
          "command": "chapterwise.moveNodeDown",
          "when": "viewItem == indexNode",
          "group": "3_move@2"
        },
        {
          "command": "chapterwise.cutNode",
          "when": "viewItem == indexNode",
          "group": "3_move@3"
        },
        {
          "command": "chapterwise.pasteNodeAsChild",
          "when": "viewItem == indexNode",
          "group": "3_move@4"
        },
        {
          "command": "chapterwise.pasteNodeAsSibling",
          "when": "viewItem == indexNode",
          "group": "3_move@5"
        },
        {
          "command": "chapterwise.goToYaml",
          "when": "viewItem == indexNode",
          "group": "4_navigate@1"
        },
        {
          "command": "chapterwise.copyId",
          "when": "viewItem == indexNode",
          "group": "4_navigate@2"
        },
        {
          "command": "chapterwise.duplicateNode",
          "when": "viewItem == indexNode",
          "group": "4_navigate@3"
        },
        {
          "command": "chapterwise.moveToTrash",
          "when": "viewItem == indexNode",
          "group": "5_delete@1"
        },
        {
          "command": "chapterwise.deleteNodePermanently",
          "when": "viewItem == indexNode",
          "group": "5_delete@2"
        },
        {
          "command": "chapterwise.navigateToEntityInCodeView",
          "when": "viewItem == indexNode",
          "group": "navigation@1"
        },
        {
          "command": "chapterwise.addChildNode",
          "when": "viewItem == indexFile",
          "group": "1_add@1"
        },
        {
          "command": "chapterwise.addSiblingNode",
          "when": "viewItem == indexFile",
          "group": "1_add@2"
        },
        {
          "command": "chapterwise.addField",
          "when": "viewItem == indexFile",
          "group": "1_add@3"
        },
        {
          "command": "chapterwise.renameNode",
          "when": "viewItem == indexFile",
          "group": "2_edit@1"
        },
        {
          "command": "chapterwise.changeType",
          "when": "viewItem == indexFile",
          "group": "2_edit@2"
        },
        {
          "command": "chapterwise.changeIcon",
          "when": "viewItem == indexFile",
          "group": "2_edit@3"
        },
        {
          "command": "chapterwise.addTags",
          "when": "viewItem == indexFile",
          "group": "2_edit@4"
        },
        {
          "command": "chapterwise.moveNodeUp",
          "when": "viewItem == indexFile",
          "group": "3_move@1"
        },
        {
          "command": "chapterwise.moveNodeDown",
          "when": "viewItem == indexFile",
          "group": "3_move@2"
        },
        {
          "command": "chapterwise.cutNode",
          "when": "viewItem == indexFile",
          "group": "3_move@3"
        },
        {
          "command": "chapterwise.pasteNodeAsChild",
          "when": "viewItem == indexFile",
          "group": "3_move@4"
        },
        {
          "command": "chapterwise.pasteNodeAsSibling",
          "when": "viewItem == indexFile",
          "group": "3_move@5"
        },
        {
          "command": "chapterwise.openInFinder",
          "when": "viewItem == indexFile",
          "group": "4_navigate@1"
        },
        {
          "command": "chapterwise.copyPath",
          "when": "viewItem == indexFile",
          "group": "4_navigate@2"
        },
        {
          "command": "chapterwise.duplicateNode",
          "when": "viewItem == indexFile",
          "group": "4_navigate@3"
        },
        {
          "command": "chapterwise.inlineThisFile",
          "when": "viewItem == indexFile",
          "group": "4_navigate@4"
        },
        {
          "command": "chapterwise.moveToTrash",
          "when": "viewItem == indexFile",
          "group": "5_delete@1"
        },
        {
          "command": "chapterwise.deleteNodePermanently",
          "when": "viewItem == indexFile",
          "group": "5_delete@2"
        },
        {
          "command": "chapterwise.addChildFile",
          "when": "viewItem == indexFolder",
          "group": "1_add@1"
        },
        {
          "command": "chapterwise.addChildFolder",
          "when": "viewItem == indexFolder",
          "group": "1_add@2"
        },
        {
          "command": "chapterwise.renameFolder",
          "when": "viewItem == indexFolder",
          "group": "2_edit@1"
        },
        {
          "command": "chapterwise.openInFinder",
          "when": "viewItem == indexFolder",
          "group": "4_navigate@1"
        },
        {
          "command": "chapterwise.moveToTrash",
          "when": "viewItem == indexFolder",
          "group": "5_delete@1"
        },
        {
          "command": "chapterwise.renameField",
          "when": "viewItem == codexField",
          "group": "2_edit@1"
        },
        {
          "command": "chapterwise.goToYaml",
          "when": "viewItem == codexField",
          "group": "4_navigate@1"
        },
        {
          "command": "chapterwise.deleteField",
          "when": "viewItem == codexField",
          "group": "5_delete@1"
        },
        {
          "command": "chapterwise.renameField",
          "when": "viewItem == indexField",
          "group": "2_edit@1"
        },
        {
          "command": "chapterwise.goToYaml",
          "when": "viewItem == indexField",
          "group": "4_navigate@1"
        },
        {
          "command": "chapterwise.deleteField",
          "when": "viewItem == indexField",
          "group": "5_delete@1"
        },
        {
          "command": "chapterwise.navigateToFieldInCodeView",
          "when": "viewItem == indexField",
          "group": "navigation@1"
        },
        {
          "command": "chapterwise.batchMoveToTrash",
          "when": "viewItem == codexNode && listMultiSelection",
          "group": "5_delete@1"
        },
        {
          "command": "chapterwise.batchAddTags",
          "when": "viewItem == codexNode && listMultiSelection",
          "group": "2_edit@1"
        },
        {
          "command": "chapterwise.batchMoveToTrash",
          "when": "viewItem == indexNode && listMultiSelection",
          "group": "5_delete@1"
        },
        {
          "command": "chapterwise.batchAddTags",
          "when": "viewItem == indexNode && listMultiSelection",
          "group": "2_edit@1"
        },
        {
          "command": "chapterwise.batchMoveToTrash",
          "when": "viewItem == indexFile && listMultiSelection",
          "group": "5_delete@1"
        },
        {
          "command": "chapterwise.batchAddTags",
          "when": "viewItem == indexFile && listMultiSelection",
          "group": "2_edit@1"
        }
      ],
      "view/item/inline": [
        {
          "command": "chapterwise.navigateToEntityInCodeView",
          "when": "viewItem == indexNode",
          "group": "inline"
        },
        {
          "command": "chapterwise.navigateToFieldInCodeView",
          "when": "viewItem == indexField",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "chapterwise.createIndexFile",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "chapterwise.generateIndex",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "chapterwise.regenerateIndex",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "chapterwise.git.setupWizard",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "chapterwise.git.initRepository",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "chapterwise.git.ensureGitIgnore",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "chapterwise.git.setupLFS",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "chapterwise.importScrivener",
          "when": "true"
        },
        {
          "command": "chapterwise.rebuildSearchIndex",
          "when": "chapterwise.hasContext"
        }
      ]
    },
    "keybindings": [
      {
        "command": "chapterwise.search",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f",
        "when": "focusedView =~ /^chapterwise/"
      },
      {
        "command": "chapterwise.openWriterView",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w",
        "when": "editorTextFocus && resourceFilename =~ /\\.codex\\.(yaml|json)$/"
      },
      {
        "command": "workbench.view.extension.chapterwise",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "resourceFilename =~ /\\.codex\\.(yaml|json)$/"
      },
      {
        "command": "chapterwise.addChildNode",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "focusedView =~ /^chapterwise/"
      },
      {
        "command": "chapterwise.addSiblingNode",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "focusedView =~ /^chapterwise/"
      },
      {
        "command": "chapterwise.renameNode",
        "key": "f2",
        "when": "focusedView =~ /^chapterwise/"
      },
      {
        "command": "chapterwise.changeColor",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "focusedView =~ /^chapterwise/"
      },
      {
        "command": "chapterwise.duplicateNode",
        "key": "ctrl+d",
        "mac": "cmd+d",
        "when": "focusedView =~ /^chapterwise/"
      },
      {
        "command": "chapterwise.cutNode",
        "key": "ctrl+x",
        "mac": "cmd+x",
        "when": "focusedView =~ /^chapterwise/"
      },
      {
        "command": "chapterwise.pasteNodeAsChild",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "focusedView =~ /^chapterwise/"
      },
      {
        "command": "chapterwise.moveToTrash",
        "key": "delete",
        "mac": "delete",
        "when": "focusedView =~ /^chapterwise/"
      },
      {
        "command": "chapterwise.deleteNodePermanently",
        "key": "shift+delete",
        "mac": "shift+delete",
        "when": "focusedView =~ /^chapterwise/"
      },
      {
        "command": "chapterwise.moveNodeUp",
        "key": "ctrl+up",
        "mac": "cmd+up",
        "when": "focusedView =~ /^chapterwise/"
      },
      {
        "command": "chapterwise.moveNodeDown",
        "key": "ctrl+down",
        "mac": "cmd+down",
        "when": "focusedView =~ /^chapterwise/"
      }
    ],
    "snippets": [
      {
        "language": "yaml",
        "path": "./snippets/codex.code-snippets"
      }
    ],
    "languages": [
      {
        "id": "yaml",
        "extensions": [
          ".codex.yaml",
          ".codex"
        ]
      },
      {
        "id": "json",
        "extensions": [
          ".codex.json"
        ]
      }
    ],
    "configuration": {
      "title": "ChapterWise",
      "properties": {
        "chapterwise.showFieldsInTree": {
          "type": "boolean",
          "default": true,
          "description": "Show field entries (body, summary, attributes, content) as expandable children under nodes in the ChapterWise Navigator tree"
        },
        "chapterwise.navigator.defaultChildMode": {
          "type": "string",
          "enum": [
            "inline",
            "separate-file",
            "ask"
          ],
          "default": "ask",
          "description": "How to create new child nodes: inline (in same file), separate-file (new file), or ask (prompt each time)"
        },
        "chapterwise.navigator.fileOrganization.strategy": {
          "type": "string",
          "enum": [
            "organized",
            "data-folder",
            "flat"
          ],
          "default": "organized",
          "description": "File organization strategy: organized (hierarchical folders), data-folder (Scrivener-style UUID storage), or flat (same directory)"
        },
        "chapterwise.navigator.fileOrganization.dataFolderPath": {
          "type": "string",
          "default": "Files/Data",
          "description": "Path for data-folder strategy (relative to workspace root)"
        },
        "chapterwise.navigator.fileOrganization.useUuidFilenames": {
          "type": "boolean",
          "default": false,
          "description": "Use UUID filenames instead of name-based filenames"
        },
        "chapterwise.navigator.naming.slugify": {
          "type": "boolean",
          "default": true,
          "description": "Convert node names to URL-friendly slugs (e.g., 'Chapter 1' → 'chapter-01')"
        },
        "chapterwise.navigator.naming.separator": {
          "type": "string",
          "default": "-",
          "description": "Separator character for slugified names"
        },
        "chapterwise.navigator.naming.includeType": {
          "type": "boolean",
          "default": false,
          "description": "Include type prefix in filename (e.g., 'character-aya.yaml')"
        },
        "chapterwise.navigator.automation.autoSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically save files after structural changes"
        },
        "chapterwise.navigator.automation.autoGenerateIds": {
          "type": "boolean",
          "default": true,
          "description": "Automatically generate UUIDs for new nodes"
        },
        "chapterwise.navigator.automation.autoGenerateIndex": {
          "type": "boolean",
          "default": true,
          "description": "Automatically regenerate index after file operations"
        },
        "chapterwise.navigator.safety.confirmDelete": {
          "type": "boolean",
          "default": true,
          "description": "Show confirmation dialog before deleting nodes"
        },
        "chapterwise.navigator.safety.backupBeforeDestruct": {
          "type": "boolean",
          "default": true,
          "description": "Create backup before permanent deletion"
        },
        "chapterwise.navigator.colors.inheritFromParent": {
          "type": "boolean",
          "default": false,
          "description": "Children inherit parent node colors if not explicitly set"
        },
        "chapterwise.navigator.colors.showInheritedDimmed": {
          "type": "boolean",
          "default": true,
          "description": "Show inherited colors with reduced opacity"
        },
        "chapterwise.images.organization": {
          "type": "string",
          "enum": [
            "perNode",
            "sharedWithNodeFolders"
          ],
          "enumDescriptions": [
            "Images folder next to codex file (e.g., /characters/aya/images/portrait.png)",
            "Shared images folder with node subfolders (e.g., /characters/images/aya/portrait.png)"
          ],
          "default": "sharedWithNodeFolders",
          "description": "How imported images are organized in the workspace"
        },
        "chapterwise.writerView.theme": {
          "type": "string",
          "enum": [
            "light",
            "dark",
            "system",
            "theme"
          ],
          "default": "theme",
          "enumDescriptions": [
            "Always use light theme",
            "Always use dark theme",
            "Follow your operating system's light/dark mode setting",
            "Adapt to your current VS Code theme colors"
          ],
          "description": "Color theme for the Writer View prose editor"
        },
        "chapterwise.indexDisplayMode": {
          "type": "string",
          "enum": [
            "nested",
            "stacked",
            "tabs"
          ],
          "enumDescriptions": [
            "Show all indexes merged into single tree (current behavior)",
            "Show each index as a separate collapsible section",
            "Show each index in a tabbed interface (future)"
          ],
          "default": "stacked",
          "description": "How to display multiple index.codex.yaml files in the navigator"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "compile:tsc": "tsc -p ./",
    "pretest": "npm run compile",
    "typecheck": "tsc -p ./ --noEmit",
    "lint": "eslint src/",
    "package": "vsce package",
    "test": "npm run typecheck && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "compile:tests": "tsc -p tsconfig.test.json && cp -r src/test/fixtures out/test/",
    "test:integration": "npm run compile && npm run compile:tests && node out/test/runTest.js"
  },
  "dependencies": {
    "minimatch": "^9.0.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/glob": "^8.1.0",
    "@types/minimatch": "^5.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.80.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.2",
    "eslint": "^10.0.3",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.4"
  }
}
